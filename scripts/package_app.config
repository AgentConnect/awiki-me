# AWiki Me 客户端打包配置。
#
# 脚本固定输出 Android arm64 debug APK、macOS arm64 profile DMG 和 macOS x64 profile DMG。
# 产物固定写入仓库内的 dist/<channel>/<version>/。
#
# 分发轨道。
# 它只用于隔离输出目录、文件名和 latest.json，不代表应用商店发布状态，也不控制代码签名。
PACKAGE_CHANNEL="test"

# 一键切换的服务域名。打包脚本会从这里推导 AWIKI_BASE_URL、DID 域名、
# ANP 服务、Daemon 下载地址和默认 App 更新清单。
#
# 常用值:
#   AWIKI_DOMAIN="awiki.ai"
#   AWIKI_DOMAIN="awiki.info"
AWIKI_DOMAIN="awiki.ai"

# 高级覆盖项。默认留空即可跟随 AWIKI_DOMAIN：
#   AWIKI_BASE_URL                  -> https://$AWIKI_DOMAIN
#   AWIKI_SERVICE_BASE_URL          -> $AWIKI_BASE_URL
#   AWIKI_USER_SERVICE_URL          -> $AWIKI_BASE_URL
#   AWIKI_MESSAGE_SERVICE_URL       -> $AWIKI_BASE_URL
#   AWIKI_MAIL_SERVICE_URL          -> $AWIKI_BASE_URL
#   AWIKI_DID_DOMAIN                -> $AWIKI_DOMAIN
#   AWIKI_STATE_NAMESPACE           -> $AWIKI_DID_DOMAIN
#   AWIKI_ANP_SERVICE_URL           -> $AWIKI_BASE_URL/anp-im/rpc
#   AWIKI_ANP_SERVICE_DID           -> did:wba:$AWIKI_DID_DOMAIN
#   AWIKI_DAEMON_DOWNLOAD_BASE_URL  -> $AWIKI_BASE_URL/daemon
#   AWIKI_UPDATE_MANIFEST_URL       -> $AWIKI_BASE_URL/downloads/awiki-me/$PACKAGE_CHANNEL/latest.json
#   AWIKI_RELEASES_URL              -> $AWIKI_BASE_URL/#download
AWIKI_BASE_URL=""
AWIKI_SERVICE_BASE_URL=""
AWIKI_USER_SERVICE_URL=""
AWIKI_MESSAGE_SERVICE_URL=""
AWIKI_MAIL_SERVICE_URL=""
AWIKI_DID_DOMAIN=""
AWIKI_STATE_NAMESPACE=""
AWIKI_ANP_SERVICE_URL=""
AWIKI_ANP_SERVICE_DID=""
AWIKI_DAEMON_DOWNLOAD_BASE_URL=""
AWIKI_UPDATE_MANIFEST_URL=""
AWIKI_RELEASES_URL=""

# 版本递增方式：build、patch、minor、major 或 none。
PACKAGE_VERSION_BUMP="build"
