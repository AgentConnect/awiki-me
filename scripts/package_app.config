# AWiki Me 客户端打包配置。
#
# 脚本固定使用 release 模式，并固定输出 Android arm64 APK、macOS arm64 DMG 和 macOS x64 DMG。产物固定写入仓库内的 dist/<channel>/<version>/。
#
# 分发轨道。
# 它只用于隔离输出目录、文件名和 latest.json，不代表应用商店发布状态，也不控制代码签名。
PACKAGE_CHANNEL="test"

# 后端根地址。App 会从这个地址自动推导用户服务、消息服务、邮件服务、DID 域名、ANP 服务和 Daemon 下载地址。
AWIKI_BASE_URL="https://anpclaw.com"

# 版本递增方式：build、patch、minor、major 或 none。
PACKAGE_VERSION_BUMP="build"
