# AWiki Me 客户端打包配置。
#
# 脚本固定输出 Android arm64 debug APK、macOS arm64 profile DMG 和 macOS x64 profile DMG。
# 产物固定写入仓库内的 dist/<channel>/<version>/。
#
# 分发轨道。
# 它只用于隔离输出目录、文件名和 latest.json，不代表应用商店发布状态，也不控制代码签名。
PACKAGE_CHANNEL="test"

# 后端根地址。App 会从这个地址自动推导用户服务、消息服务、邮件服务、DID 域名、ANP 服务和 Daemon 下载地址。
AWIKI_BASE_URL="https://awiki.ai"

# App 更新清单和人工下载页。发布包直接读取 awiki.ai 静态分发路径，不再回退到 GitHub。
AWIKI_UPDATE_MANIFEST_URL="https://awiki.ai/downloads/awiki-me/test/latest.json"
AWIKI_RELEASES_URL="https://awiki.ai/#download"

# 版本递增方式：build、patch、minor、major 或 none。
PACKAGE_VERSION_BUMP="patch"
