# AWiki Me app packaging configuration.
#
# This file is the single source of truth for scripts/package_app.sh. Do not
# pass build target, backend URL, version bump, or output settings through
# command-line arguments or environment variables.
#
# Relative paths are resolved from the repository root.

# Product identity.
PACKAGE_APP_DISPLAY_NAME="AWiki Me"
PACKAGE_ANDROID_APP_ID="ai.awiki.awikime"
PACKAGE_MACOS_BUNDLE_ID="ai.awiki.awikiMe"

# Distribution identity.
# Use "test" with https://anpclaw.com for online test packages.
# Use "stable" with https://awiki.info for production packages.
PACKAGE_CHANNEL="test"

# Flutter build mode: debug, profile, or release.
PACKAGE_BUILD_MODE="debug"

# Versioning.
# PACKAGE_VERSION_BUMP: build, patch, minor, major, or none.
# PACKAGE_VERSION_NAME can set x.y.z explicitly. When set, keep
# PACKAGE_VERSION_BUMP="build" so the build number still moves forward.
PACKAGE_VERSION_BUMP="build"
PACKAGE_VERSION_NAME=""

# Set to 1 to validate the package plan without modifying pubspec.yaml or
# building artifacts.
PACKAGE_DRY_RUN=0

# Outputs are written to:
#   ${PACKAGE_DIST_ROOT}/${PACKAGE_CHANNEL}/${version}/
# and latest metadata to:
#   ${PACKAGE_DIST_ROOT}/${PACKAGE_CHANNEL}/latest.json
PACKAGE_DIST_ROOT="dist/app"

# Build targets.
PACKAGE_BUILD_ANDROID_ARM64=1
PACKAGE_BUILD_MACOS_ARM64=1
PACKAGE_BUILD_MACOS_X64=1

# Native SDK artifacts are normally rebuilt before packaging.
PACKAGE_BUILD_SDK_NATIVE=1
PACKAGE_SDK_REPO_DIR="../awiki-cli-rs2"
PACKAGE_SDK_NATIVE_BUILD_SCRIPT=""

# Tooling.
PACKAGE_FLUTTER_BIN="flutter"

# Android APK signing certificate pin. Leave empty only when intentionally
# switching signing material, for example a future release signing setup.
PACKAGE_ANDROID_EXPECTED_CERT_SHA256="F2:67:E9:18:57:54:ED:C1:2B:E5:69:69:1B:39:B9:EF:D4:EF:1E:CF:2D:7E:D8:18:81:42:69:B3:70:85:D8:75"

# Backend / runtime compile-time configuration.
# AWIKI_BASE_URL is required. The app derives user-service, message-service,
# mail-service, DID domain, ANP service, and daemon download root from it unless
# an explicit override below is set.
AWIKI_BASE_URL="https://anpclaw.com"
AWIKI_USER_SERVICE_URL=""
AWIKI_MESSAGE_SERVICE_URL=""
AWIKI_MAIL_SERVICE_URL=""
AWIKI_DID_DOMAIN=""
AWIKI_ANP_SERVICE_URL=""
AWIKI_ANP_SERVICE_DID=""
AWIKI_DAEMON_DOWNLOAD_BASE_URL=""
AWIKI_AGENT_IM_ENABLED="true"

# App update URLs. Leave empty to use app defaults.
AWIKI_UPDATE_MANIFEST_URL=""
AWIKI_RELEASES_URL=""
