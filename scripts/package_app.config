# AWiki Me 客户端打包配置。
#
# 脚本固定输出 Android arm64 release APK、macOS arm64 profile DMG 和 macOS x64 profile DMG。
# 安装包固定写入仓库内的 dist/<version>/，最新版清单固定写入 dist/latest.json。

# 发布域名。租户后端和 DID Host 不再在打包时写入 App；它们由 App
# 登录页里的租户管理入口创建和切换。这里的域名只用于生成下载地址、
# 更新清单和发布页等打包产物元数据。
#
# 常用值:
#   AWIKI_DOMAIN="awiki.ai"
#   AWIKI_DOMAIN="awiki.info"
AWIKI_DOMAIN="awiki.ai"

# 发布元数据覆盖项。默认留空即可跟随 AWIKI_DOMAIN：
#   AWIKI_DAEMON_DOWNLOAD_BASE_URL -> https://$AWIKI_DOMAIN/daemon
#   AWIKI_UPDATE_MANIFEST_URL      -> https://$AWIKI_DOMAIN/downloads/awiki-me/latest.json
#   AWIKI_RELEASES_URL             -> https://$AWIKI_DOMAIN/#download
AWIKI_DAEMON_DOWNLOAD_BASE_URL=""
AWIKI_UPDATE_MANIFEST_URL=""
AWIKI_RELEASES_URL=""

# 版本递增方式：build、patch、minor、major 或 none。
PACKAGE_VERSION_BUMP="build"

# Android 启动冒烟验证：auto、always 或 never。
# auto 只会在发现一个 Android 模拟器时安装并启动验证，不会自动安装到真机。
PACKAGE_ANDROID_STARTUP_SMOKE_TEST="auto"
