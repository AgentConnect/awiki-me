# AWiki Me 客户端打包配置。
#
# 默认输出 Android arm64 release APK、macOS 双架构 DMG 和 Windows x64 EXE。
# 安装包固定写入仓库内的 dist/<version>/，最新版清单固定写入 dist/latest.json。

# 发布下载域名。这里只控制安装包、latest.json 等发布产物的下载地址。
# 租户后端和 DID Host 不会在打包时写入 App；它们由 App 登录页里的
# 租户管理入口创建和切换。
#
# 常用值:
#   PACKAGE_RELEASE_DOMAIN="awiki.ai"
#   PACKAGE_RELEASE_DOMAIN="awiki.info"
PACKAGE_RELEASE_DOMAIN="awiki.ai"

# App 内置 AWiki 主租户的编译域名。只填写小写 hostname，不包含协议或路径。
# 构建时也可以用 scripts/package_app.sh --primary-tenant-domain <domain>
# 临时覆盖；不传参数时继续使用这里的默认值。
PACKAGE_PRIMARY_TENANT_DOMAIN="awiki.ai"

# 发布元数据覆盖项。默认留空即可跟随 PACKAGE_RELEASE_DOMAIN。
# 这里配置的是发布产物的公网地址，用于生成 latest.json 里的下载链接；
# 不会改变 App 内置的更新检查地址。
#   PACKAGE_UPDATE_MANIFEST_PUBLIC_URL -> https://$PACKAGE_RELEASE_DOMAIN/downloads/awiki-me/latest.json
#   PACKAGE_DOWNLOAD_PAGE_URL          -> https://$PACKAGE_RELEASE_DOMAIN/#download
PACKAGE_UPDATE_MANIFEST_PUBLIC_URL=""
PACKAGE_DOWNLOAD_PAGE_URL=""

# 发布版本必须先提交到 pubspec.yaml。打包过程不得修改受 Git 跟踪的源码，
# 否则产物记录的 source ref 不能准确代表实际构建输入。
PACKAGE_VERSION_BUMP="none"

# 本次要打包的发布目标。多个目标用英文逗号或空格分隔。
# 可选值：
#   android-arm64  生成 Android arm64 APK，只需要 Android/Flutter 构建环境。
#   macos-arm64    生成 Apple Silicon Mac DMG，需要 macOS/Xcode 构建环境。
#   macos-x64      生成 Intel Mac DMG，需要 macOS/Xcode 构建环境。
#   windows-x64    生成 Windows x64 Inno Setup EXE，由 windows-2022 worker 构建。
#
# 常用示例：
#   PACKAGE_TARGETS="android-arm64,macos-arm64,macos-x64,windows-x64"  # 全平台
#   PACKAGE_TARGETS="android-arm64"                        # 只打 Android
#   PACKAGE_TARGETS="macos-arm64,macos-x64"                # 只打 macOS 双架构
#   PACKAGE_TARGETS="windows-x64"                          # 只打 Windows
PACKAGE_TARGETS="android-arm64,macos-arm64,macos-x64,windows-x64"

# GitHub Actions 打包工作流。工作流由仓库默认分支稳定注册，但实际
# APP/Core 源码使用当前任意已推送分支的精确 SHA。package_app.sh 只负责
# 调度、等待和下载，不在 Mac 本机修改 pubspec.yaml 或编译平台产物。
PACKAGE_WORKFLOW_FILE="package-app.yml"
PACKAGE_RUN_DISCOVERY_TIMEOUT_SECONDS="180"

# ANP 必须同时匹配 awiki-cli-rs2 release config 中的固定提交。
PACKAGE_ANP_SOURCE_REF="67e6680fac80a5fb3dca41029c67a0ea3ecc0dd5"

# macOS 试用包必须使用固定的非 ad-hoc 签名身份。真实值不要写在本文件里：
# - 本地发布：复制 package_app.local.config.example 为 package_app.local.config；
# - CI 发布：通过同名 Secret / 环境变量注入。
# 证书和私钥必须预先导入 Keychain，任何 .p12/.pfx 都不得放进仓库。
AWIKI_MACOS_SIGNING_IDENTITY="${AWIKI_MACOS_SIGNING_IDENTITY:-}"
AWIKI_MACOS_DEVELOPMENT_TEAM="${AWIKI_MACOS_DEVELOPMENT_TEAM:-}"
