// Application-level settings for the Runner target.
//
// This may be replaced with something auto-generated from metadata (e.g., pubspec.yaml) in the
// future. If not, the values below would default to using the project name when this becomes a
// 'flutter create' template.

// CocoaPods generated settings. These files are created by `pod install`;
// optional includes keep the project loadable before bootstrap.
#include? "../../Pods/Target Support Files/Pods-Runner/Pods-Runner.debug.xcconfig"
#include? "../../Pods/Target Support Files/Pods-Runner/Pods-Runner.release.xcconfig"
#include? "../../Pods/Target Support Files/Pods-Runner/Pods-Runner.profile.xcconfig"

// The application's name. By default this is also the title of the Flutter window.
PRODUCT_NAME = AWikiMe

// The application's bundle identifier
PRODUCT_BUNDLE_IDENTIFIER = ai.awiki.awikime

// The compile-time built-in tenant. Packaging overrides this together with the
// matching Dart define and records the value in the signed App Info.plist.
AWIKI_PRIMARY_TENANT_DOMAIN = awiki.ai

// Fallback CocoaPods paths for direct Xcode builds.
//
// Xcode resolves the [CP] file-list paths before it can print the manifest
// check error when Pods have not been generated yet. Keeping canonical paths
// here prevents empty ${PODS_ROOT} expansion such as:
//   /Target Support Files/Pods-Runner/...
// If these files are missing, run scripts/prepare_macos_build.sh to regenerate
// macos/Pods and open Runner.xcworkspace.
PODS_ROOT = ${SRCROOT}/Pods
PODS_PODFILE_DIR_PATH = ${SRCROOT}

// The copyright displayed in application information
PRODUCT_COPYRIGHT = Copyright © 2026 ai.awiki. All rights reserved.

// Sparkle feed configuration for auto-updates. The URL uses `$()` to prevent
// xcconfig from treating `//` as a comment while still expanding to `https://`.
// Do not inject an empty SUPublicEDKey into Info.plist; unsigned development
// builds should omit that key until CI provides a real EdDSA public key for
// signed update artifacts.
SPARKLE_FEED_URL = https:/$()/agentconnect.github.io/awiki-me/updates/appcast.xml
